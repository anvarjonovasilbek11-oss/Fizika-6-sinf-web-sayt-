rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Foydalanuvchilar: O'zining ma'lumotlarini o'qish/yozish ruxsati (Hozircha o'qish hamma uchun, yozish faqat yangi kishilarga/admin)
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null || (resource.data.role != 'admin');
    }
    
    // Materiallar, Videolar va Testlar: Faqat Admin yoza oladi, hamma o'qiydi
    match /{collectionName}/{docId} {
      allow read: if true;
      allow write: if is_admin();
    }
    
    function is_admin() {
      // Bu yerda bizning custom admin logikamiz ishlatiladi. 
      // Haqiqiy Firebase Auth bo'lmagani uchun, xavfsizlikni koddagi admin roli orqali ta'minlaymiz.
      // Eslatma: Haqiqiy xavfsizlik uchun Firebase Auth-dan foydalanish tavsiya etiladi.
      return true; // Test rejimi tugagach, bu yerda cheklovlar qo'yiladi
    }
  }
}
